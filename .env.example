# ──────────────────────────────────────────────
# Shepherd's Compass — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Groq API keys — add as many as you have (up to 6) for automatic rotation.
# At least VITE_GROQ_API_KEY_1 (or the legacy VITE_GROQ_API_KEY) is required.
VITE_GROQ_API_KEY_1=gsk_your_first_key_here
VITE_GROQ_API_KEY_2=
VITE_GROQ_API_KEY_3=
VITE_GROQ_API_KEY_4=
VITE_GROQ_API_KEY_5=
VITE_GROQ_API_KEY_6=

# Optional: override the default model
# VITE_GROQ_MODEL=llama-3.3-70b-versatile
